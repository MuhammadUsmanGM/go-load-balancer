{
  "listen_addr": ":8080",
  "strategy": "round-robin",
  "backends": [
    {"url": "http://localhost:8081", "weight": 1},
    {"url": "http://localhost:8082", "weight": 1},
    {"url": "http://localhost:8083", "weight": 1}
  ],
  "health_check": {
    "interval": "10s",
    "path": "/health",
    "timeout": "2s"
  },
  "metrics": {
    "enabled": true,
    "path": "/metrics"
  },
  "tracing": {
    "enabled": false,
    "endpoint": "localhost:4318",
    "insecure": true,
    "service": "go-load-balancer"
  }
}
